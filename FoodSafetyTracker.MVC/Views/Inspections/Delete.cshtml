@model FoodSafetyTracker.Domain.Inspection
@{ ViewData["Title"] = "Delete Inspection"; }
<h2>Delete Inspection</h2>
<div class="alert alert-warning">Delete inspection for <strong>@Model.Premises?.Name</strong> on @Model.InspectionDate.ToShortDateString()?</div>
<form asp-action="Delete">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>
