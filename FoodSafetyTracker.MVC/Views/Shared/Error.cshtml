@model FoodSafetyTracker.MVC.Models.ErrorViewModel
@{ ViewData["Title"] = "Error"; }
<div class="alert alert-danger mt-4">
    <h2>⚠️ Something went wrong.</h2>
    <p>An unexpected error occurred. Please try again or contact support.</p>
    @if (Model.ShowRequestId)
    {
        <p><strong>Request ID:</strong> <code>@Model.RequestId</code></p>
    }
</div>
<a asp-controller="Dashboard" asp-action="Index" class="btn btn-primary">Back to Dashboard</a>
