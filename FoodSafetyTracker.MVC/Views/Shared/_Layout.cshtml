<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Food Safety Tracker</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        .navbar { background-color: #1a3c34 !important; }
        .navbar-brand, .nav-link { color: #c8e6c9 !important; }
        .nav-link:hover { color: #fff !important; }
        .badge-high { background-color: #c62828; }
        .badge-medium { background-color: #f57f17; color: #000; }
        .badge-low { background-color: #2e7d32; }
        footer { background-color: #f1f8e9; border-top: 2px solid #1a3c34; }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-dark">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold" asp-controller="Dashboard" asp-action="Index">🛡 Food Safety Tracker</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item"><a class="nav-link" asp-controller="Dashboard" asp-action="Index">Dashboard</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Premises" asp-action="Index">Premises</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Inspections" asp-action="Index">Inspections</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="FollowUps" asp-action="Index">Follow-Ups</a></li>
                    </ul>
                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav>
    </header>
    <div class="container mt-4">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>
    <footer class="py-3 mt-4">
        <div class="container text-muted text-center">
            <small>&copy; @DateTime.Now.Year Food Safety Tracker</small>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
