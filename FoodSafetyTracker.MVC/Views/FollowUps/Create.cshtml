@model FoodSafetyTracker.Domain.FollowUp
@{ ViewData["Title"] = "New Follow-Up"; }
<h2>New Follow-Up</h2>
<div class="col-md-6">
<form asp-action="Create">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="mb-3"><label asp-for="InspectionId" class="form-label">Inspection</label><select asp-for="InspectionId" asp-items="ViewBag.InspectionId" class="form-select"><option value="">-- Select --</option></select><span asp-validation-for="InspectionId" class="text-danger"></span></div>
    <div class="mb-3"><label asp-for="DueDate" class="form-label"></label><input asp-for="DueDate" type="date" class="form-control" /><span asp-validation-for="DueDate" class="text-danger"></span></div>
    <button type="submit" class="btn btn-success">Create</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>
</div>
@section Scripts { @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); } }
