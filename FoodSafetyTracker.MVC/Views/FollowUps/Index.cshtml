@model IEnumerable<FoodSafetyTracker.Domain.FollowUp>
@{ ViewData["Title"] = "Follow-Ups"; }
<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>⏰ Follow-Ups</h2>
    @if (User.IsInRole("Admin") || User.IsInRole("Inspector"))
    { <a asp-action="Create" class="btn btn-success">+ New Follow-Up</a> }
</div>
@if (TempData["Error"] is string err) { <div class="alert alert-danger">@err</div> }
<table class="table table-hover align-middle">
    <thead class="table-dark">
        <tr><th>Premises</th><th>Inspection Date</th><th>Due Date</th><th>Status</th><th>Closed</th><th></th></tr>
    </thead>
    <tbody>
    @foreach (var f in Model)
    {
        var overdue = f.Status == FollowUpStatus.Open && f.DueDate < DateTime.Today;
        <tr class="@(overdue ? "table-danger" : "")">
            <td class="fw-semibold">@f.Inspection?.Premises?.Name</td>
            <td>@f.Inspection?.InspectionDate.ToShortDateString()</td>
            <td>@f.DueDate.ToShortDateString()</td>
            <td><span class="badge @(f.Status == FollowUpStatus.Closed ? "bg-success" : overdue ? "bg-danger" : "bg-warning text-dark")">@(overdue ? "OVERDUE" : f.Status.ToString())</span></td>
            <td>@(f.ClosedDate?.ToShortDateString() ?? "–")</td>
            <td>
                @if (f.Status == FollowUpStatus.Open && (User.IsInRole("Admin") || User.IsInRole("Inspector")))
                {
                    <form asp-action="Close" asp-route-id="@f.Id" method="post" style="display:inline">
                        @Html.AntiForgeryToken()
                        <button class="btn btn-sm btn-success">✓ Close</button>
                    </form>
                }
            </td>
        </tr>
    }
    </tbody>
</table>
